---
import MainLayout from '../layouts/MainLayout.astro';
import { getSiteConfig } from '../utils/config-resolver';

const siteConfig = getSiteConfig();


// Importación de Módulos de Sección
import Hero from '../components/sections/Hero.astro';
import BentoGrid from '../components/sections/BentoGrid.astro';
import MetricsPulse from '../components/sections/MetricsPulse.astro';
import IdentityStack from '../components/sections/IdentityStack.astro';
import Timeline from '../components/sections/Timeline.astro';
import TechCarousel from '../components/sections/TechCarousel.astro';
import FallbackSection from '../components/sections/FallbackSection.astro';

/**
 * COMPONENT_MAP
 * Relaciona los "type" definidos en site-config.ts con componentes reales de Astro.
 * Esto permite una expansión fácil: solo añade una nueva entrada aquí al crear un módulo.
 */
const COMPONENT_MAP: Record<string, any> = {
  'hero': Hero,
  'bento-grid': BentoGrid,
  'metrics-pulse': MetricsPulse,
  'identity-stack': IdentityStack,
  'process-timeline': Timeline,
  'tech-carousel': TechCarousel,
};

---

<MainLayout config={siteConfig}>
	{siteConfig.layout.map((section) => {
    const Component = COMPONENT_MAP[section.type] || FallbackSection;
    return <Component {...section} title={section.data.title} />;
  })}
</MainLayout>