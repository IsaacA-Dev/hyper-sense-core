---
import type { TechCarouselData } from '../../types/config';

interface Props {
  id: string;
  data: TechCarouselData;
}

const { id, data } = Astro.props;
---

<section {id} class="py-12 md:py-24 bg-black/[0.02] dark:bg-white/[0.01] overflow-hidden reveal-item">
  {data.title && (
    <div class="container mx-auto px-6 mb-12 text-center">
      <p class="text-[9px] font-mono uppercase tracking-[0.5em] text-primary mb-3">Engine Core infrastructure</p>
      <h2 class="item-title text-2xl md:text-5xl font-black tracking-tighter uppercase">{data.title}</h2>
    </div>
  )}

  <div class="relative flex overflow-x-hidden group">
    <div class="flex animate-marquee group-hover:pause whitespace-nowrap py-12 items-center gap-16 md:gap-32">
      {[...data.technologies, ...data.technologies].map((tech) => (
        <div class="flex items-center gap-4 opacity-20 hover:opacity-100 transition-all duration-500 scale-90 hover:scale-110 cursor-default tactical-reveal">
          <img 
             src={tech.icon} 
             alt={tech.name} 
             class="w-8 h-8 md:w-12 md:h-12 grayscale group-hover:grayscale-0 transition-all filter drop-shadow-[0_0_10px_rgba(var(--brand-primary-rgb),0.2)]"
             loading="lazy"
          />
          <span class="item-title text-lg md:text-2xl font-black uppercase tracking-tighter text-txt">{tech.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-33.33%); }
  }

  .animate-marquee {
    animation: marquee 40s linear infinite;
  }

  /* Pause on hover if desired */
  .animate-marquee:hover {
    animation-play-state: paused;
  }
</style>
