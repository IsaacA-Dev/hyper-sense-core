---
import type { MetricsData } from '../../types/config';

interface Props {
	id: string;
	data: MetricsData;
}

const { id, data } = Astro.props;
---


<section {id} class="py-20 md:py-32 bg-black/[0.02] dark:bg-white/[0.01] relative overflow-hidden reveal-item">
	<div class="container mx-auto px-4 md:px-6">
		<div class="text-center mb-16 md:mb-24">
			<h2 class="section-title text-4xl md:text-7xl font-black uppercase tracking-widest mb-4">
				{data.title}
			</h2>
			<p class="text-[9px] md:text-[10px] font-mono uppercase tracking-[0.5em] text-primary">Performance Monitoring</p>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-16 md:gap-24">
			{data.stats.map((stat, index) => (
				<div class="text-center group reveal-item" style={{ transitionDelay: `${index * 150}ms` }}>
					<div class="inline-block mb-8 md:mb-12 relative">
						<!-- Tactical: SVG Circles -->
						<svg class="w-32 h-32 md:w-48 md:h-48 -rotate-90 tactical-visible">
							<circle cx="64" cy="64" r="60" md:cx="96" md:cy="96" md:r="90" class="stroke-black/5 dark:stroke-white/5 fill-none" stroke-width="4" style="cx: var(--node-cx); cy: var(--node-cy); r: var(--node-r);" />
							<circle 
								cx="64" cy="64" r="60" md:cx="96" md:cy="96" md:r="90" 
								class="progress-circle stroke-primary fill-none transition-all duration-[2000ms] ease-out" 
								stroke-width="4" 
								data-progress={stat.progress} 
								stroke-linecap="round" 
								style="cx: var(--node-cx); cy: var(--node-cy); r: var(--node-r); stroke-dasharray: var(--circumference); stroke-dashoffset: var(--circumference);" 
							/>
						</svg>

						<!-- Minimalist: Architectural Bar -->
						<div class="w-32 md:w-48 h-[2px] bg-primary/10 minimal-visible overflow-hidden relative">
							<div class="absolute inset-y-0 left-0 bg-primary animate-minimal-slide" style={`width: ${stat.progress}%`}></div>
						</div>

						<!-- Atmospheric: Fuzzy Blob -->
						<div class="w-16 h-16 md:w-24 md:h-24 bg-primary/20 blur-[40px] rounded-full atmospheric-visible animate-pulse mx-auto"></div>

						<div class="absolute inset-0 flex items-center justify-center flex-col z-10">
							<span class="item-title text-4xl md:text-6xl font-black italic md:not-italic leading-none counter" data-target={stat.value}>0</span>
							<span class="text-[10px] md:text-xs font-bold text-primary tracking-widest uppercase mt-2">{stat.suffix}</span>
						</div>
					</div>
					<h3 class="item-title text-xs md:text-lg uppercase tracking-[0.3em] font-medium text-txt/30 group-hover:text-primary transition-all duration-500">
						{stat.label}
					</h3>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	section { 
		--node-cx: 64; --node-cy: 64; --node-r: 60; 
		--circumference: 377;
	}
	@media (min-width: 768px) { 
		section { 
			--node-cx: 96; --node-cy: 96; --node-r: 90; 
			--circumference: 565;
		} 
	}

	@keyframes minimal-slide {
		from { transform: translateX(-100%); }
		to { transform: translateX(0); }
	}
	.animate-minimal-slide {
		animation: minimal-slide 1.5s cubic-bezier(0.2, 0, 0, 1) forwards;
	}

	.progress-circle {
		stroke-dashoffset: var(--circumference);
	}
</style>

<script is:inline>
	function initMetrics() {
		const observer = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					const counters = entry.target.querySelectorAll('.counter');
					const circles = entry.target.querySelectorAll('.progress-circle');
					
					circles.forEach(circle => {
						const progress = circle.getAttribute('data-progress');
						const isMobile = window.innerWidth < 768;
						const circumference = isMobile ? 377 : 565;
						const offset = circumference - (circumference * progress) / 100;
						circle.style.strokeDashoffset = offset;
					});

					counters.forEach(counter => {
						const targetStr = counter.getAttribute('data-target');
						const target = parseFloat(targetStr);
						const isDecimal = targetStr.includes('.');
						let current = 0;
						const steps = 60;
						const increment = target / steps;
						
						const updateCounter = () => {
							if (current < target) {
								current += increment;
								counter.innerText = isDecimal ? current.toFixed(1) : Math.ceil(current);
								requestAnimationFrame(updateCounter);
							} else {
								counter.innerText = targetStr;
							}
						};
						updateCounter();
					});
					observer.unobserve(entry.target);
				}
			});
		}, { threshold: 0.1 });

		document.querySelectorAll('section').forEach(section => {
			if (section.querySelector('.counter')) observer.observe(section);
		});
	}

	initMetrics();
	document.addEventListener('astro:page-load', initMetrics);
	document.addEventListener('astro:after-swap', initMetrics);
</script>

