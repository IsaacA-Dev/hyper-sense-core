---
interface Props {
	id: string;
	data: {
		title: string;
		items: { title: string; description: string; size: 'large' | 'small'; icon: string }[];
	};
}

const { id, data } = Astro.props;
---

<section {id} class="py-32 px-6 container mx-auto">
	<div class="mb-20">
		<h2 class="text-4xl md:text-6xl font-black italic uppercase tracking-tighter mb-4">
			{data.title}
		</h2>
		<div class="w-24 h-[2px] bg-primary"></div>
	</div>

	<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
		{data.items.map((item, index) => (
			<div class={`
				group relative overflow-hidden rounded-3xl tactical-border glass p-8 md:p-10 flex flex-col justify-end min-h-[260px] md:min-h-[300px]
				${item.size === 'large' ? 'md:col-span-2' : 'md:col-span-1'}
			`}>
				<!-- Icon / Meta -->
				<div class="absolute top-10 right-10 opacity-20 group-hover:opacity-100 group-hover:text-primary transition-all duration-500 scale-150">
					<span class="text-4xl">#</span>
				</div>

				<div class="relative z-10 transition-transform duration-500 group-hover:-translate-y-2">
					<p class="text-[10px] font-mono uppercase tracking-[0.3em] text-primary mb-4">Módulo {index + 1}</p>
					<h3 class="text-2xl md:text-3xl font-bold mb-4 italic uppercase leading-none">{item.title}</h3>
					<p class="text-txt/40 text-sm leading-relaxed max-w-sm">{item.description}</p>
				</div>

				<!-- Subtle hover gradient -->
				<div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
			</div>
		))}
	</div>
</section>
