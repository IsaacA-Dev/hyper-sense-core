---
interface Props {
	id: string;
	data: {
		title: string;
		steps: { title: string; date: string; description: string }[];
	};
}

const { id, data } = Astro.props;
---

<section {id} class="py-40 px-6 container mx-auto">
	<div class="text-center mb-32">
		<h2 class="text-5xl md:text-7xl font-black italic uppercase tracking-tighter mb-4">{data.title}</h2>
		<div class="flex justify-center gap-2">
			<div class="w-2 h-2 rounded-full bg-primary/20"></div>
			<div class="w-8 h-2 rounded-full bg-primary"></div>
			<div class="w-2 h-2 rounded-full bg-primary/20"></div>
		</div>
	</div>

	<div class="relative max-w-4xl mx-auto">
		<!-- Vertical Line -->
		<div class="absolute left-0 md:left-1/2 top-0 bottom-0 w-[1px] bg-gradient-to-b from-primary via-primary/5 to-transparent -translate-x-1/2"></div>

		<div class="space-y-32">
			{data.steps.map((step, index) => (
				<div class={`relative flex flex-col md:flex-row items-center gap-12 ${index % 2 === 0 ? 'md:flex-row-reverse' : ''}`}>
					
					<!-- Point -->
					<div class="absolute left-0 md:left-1/2 w-4 h-4 bg-primary rounded-full -translate-x-1/2 z-20 shadow-[0_0_15px_rgba(var(--brand-primary-rgb),0.5)]">
						<div class="absolute inset-0 bg-primary animate-ping rounded-full opacity-20"></div>
					</div>

					<div class="w-full md:w-1/2 text-left md:text-right pl-8 md:pl-0">
						{index % 2 !== 0 && <div class="text-left">
							<span class="text-xs font-mono text-primary mb-2 block tracking-widest uppercase">{step.date}</span>
							<h3 class="text-2xl md:text-3xl font-black italic uppercase mb-4 tracking-tight">{step.title}</h3>
							<p class="text-txt/40 text-sm leading-relaxed max-w-sm ml-0">{step.description}</p>
						</div>}
						
						{index % 2 === 0 && <div class="text-left md:text-right">
							<span class="text-xs font-mono text-primary mb-2 block tracking-widest uppercase">{step.date}</span>
							<h3 class="text-2xl md:text-3xl font-black italic uppercase mb-4 tracking-tight">{step.title}</h3>
							<p class="text-txt/40 text-sm leading-relaxed max-w-sm md:ml-auto">{step.description}</p>
						</div>}
					</div>

					<div class="hidden md:block w-1/2"></div>
				</div>
			))}
		</div>
	</div>
</section>
