---
import { resolvePath } from '../../utils/paths';
import Badge from '../atomics/Badge.astro';

interface Props {
	id: string;
	data: {
		title: string;
		highlight: string;
		description: string;
	};
}

const { id, data } = Astro.props;
---

<section {id} class="relative min-h-[90vh] md:min-h-screen flex flex-col items-center justify-center p-4 md:p-6 text-center overflow-hidden">
	<!-- Background Glow -->
	<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-4xl h-64 md:h-96 bg-primary/20 dark:bg-primary/10 blur-[100px] md:blur-[150px] rounded-full -z-10 animate-pulse"></div>
	<div class="absolute top-1/4 left-1/4 w-32 h-32 bg-accent/20 blur-[80px] rounded-full -z-10 animate-blob"></div>
	<div class="absolute bottom-1/4 right-1/4 w-32 h-32 bg-primary/20 blur-[80px] rounded-full -z-10 animate-blob animation-delay-2000"></div>

	<Badge text="Core Showcase Active" className="mb-8 md:mb-12 animate-in fade-in slide-in-from-bottom-4 duration-1000 border-primary/30" />

	<h1 class="text-5xl md:text-[10rem] font-black tracking-tighter mb-6 md:mb-8 italic leading-[0.9] md:leading-[0.85] uppercase">
		<span class="text-txt dark:text-txt">{data.title}</span> <br />
		<span class="text-transparent bg-clip-text bg-gradient-to-br from-primary to-accent drop-shadow-[0_10px_30px_rgba(var(--brand-primary-rgb),0.3)] inline-block px-4">
			{data.highlight}
		</span>
	</h1>
	
	<p class="max-w-xl text-txt/60 dark:text-txt/50 text-sm md:text-xl font-light mb-10 md:mb-12 leading-relaxed tracking-wide px-4 md:px-0">
		<span class="text-primary/80 font-medium">//</span> {data.description}
	</p>



	<div class="flex flex-col sm:flex-row gap-4 md:gap-6 w-full sm:w-auto px-6 sm:px-0">
		<a href="#" class="bg-primary text-white text-[10px] md:text-xs uppercase tracking-[0.2em] px-8 md:px-12 py-4 md:py-5 rounded-sm font-bold hover:scale-105 transition-all shadow-2xl shadow-primary/20 text-center">
			Explorar Sistema
		</a>
		<a href="#" class="bg-black/5 dark:bg-white/5 border border-black/10 dark:border-white/5 text-[10px] md:text-xs uppercase tracking-[0.2em] px-8 md:px-12 py-4 md:py-5 rounded-sm font-bold hover:bg-black/10 dark:hover:bg-white/10 transition-all text-center">
			Especificaciones
		</a>
	</div>

	<!-- Scroll indicator -->
	<div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce opacity-20 hidden md:block">
		<div class="w-[1px] h-16 bg-gradient-to-b from-primary to-transparent"></div>
	</div>
</section>

