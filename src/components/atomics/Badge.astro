---
interface Props {
	text: string;
	className?: string;
}

const { text, className = "" } = Astro.props;
---

<div class={`inline-flex items-center gap-2.5 px-4 py-1.5 bg-black/5 dark:bg-white/[0.03] border border-black/10 dark:border-white/10 rounded-lg md:rounded-xl backdrop-blur-md shadow-xl ${className}`}>
	<span class="w-1.5 h-1.5 rounded-full bg-primary shadow-[0_0_10px_rgba(var(--brand-primary-rgb),0.8)] animate-pulse"></span>
	<span class="text-[10px] md:text-[11px] font-black uppercase tracking-[0.2em] text-txt/80 dark:text-txt/90 font-mono italic">
		{text}
	</span>
</div>


