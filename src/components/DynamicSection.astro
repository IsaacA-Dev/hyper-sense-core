---
import Hero from './modules/Hero.astro';
import BentoGrid from './modules/BentoGrid.astro';
import MetricsPulse from './modules/MetricsPulse.astro';
import IdentityStack from './modules/IdentityStack.astro';
import Timeline from './modules/Timeline.astro';

interface Props {
	section: any;
}

const { section } = Astro.props;
---

{section.type === 'hero' && <Hero id={section.id} data={section.data} />}
{section.type === 'bento-grid' && <BentoGrid id={section.id} data={section.data} />}
{section.type === 'metrics-pulse' && <MetricsPulse id={section.id} data={section.data} />}
{section.type === 'identity-stack' && <IdentityStack id={section.id} data={section.data} />}
{section.type === 'process-timeline' && <Timeline id={section.id} data={section.data} />}
