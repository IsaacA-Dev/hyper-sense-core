---
import { ClientRouter } from 'astro:transitions';
import { resolvePath } from '../utils/paths';
import '../styles/global.css';
import type { ShowcaseConfig } from '../data/showcase';

interface Props {
	config: ShowcaseConfig;
	title?: string;
}

const { config, title } = Astro.props;
const { theme, brand } = config;

// Inyección dinámica de variables CSS
const dynamicStyles = `
  :root {
    --brand-primary: ${theme.colors.primary};
    --brand-secondary: ${theme.colors.secondary};
    --brand-accent: ${theme.colors.accent};
    --brand-surface: ${theme.colors.surface};
    --brand-background: ${theme.colors.background};
    --brand-text: ${theme.colors.text};
    --font-display: ${theme.fonts.display};
    --font-body: ${theme.fonts.body};
  }
`;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={resolvePath("/favicon.svg")} />
		<meta name="generator" content={Astro.generator} />
		<title>{title ? `${title} | ${brand.name}` : `${brand.name} | ${brand.slogan}`}</title>
		
		<ClientRouter />

		<style is:global set:html={dynamicStyles} />
	</head>
	<body class="bg-brand-background text-brand-text font-body selection:bg-brand-primary/30 antialiased overflow-x-hidden">
		<!-- Global Glow Effects -->
		<div class="fixed top-0 left-0 w-full h-full pointer-events-none -z-10">
			<div class="absolute top-[-10%] right-[-10%] w-[50%] h-[50%] bg-brand-primary/5 blur-[150px] rounded-full"></div>
			<div class="absolute bottom-[-10%] left-[-10%] w-[50%] h-[50%] bg-brand-accent/5 blur-[150px] rounded-full"></div>
		</div>

		<header class="fixed top-0 w-full z-50 bg-brand-background/80 backdrop-blur-xl border-b border-white/5">
			<nav class="container mx-auto px-6 h-16 flex items-center justify-between">
				<a href="#" class="text-xl font-bold tracking-tighter flex items-center gap-2 group transition-all">
					<div class="w-6 h-6 bg-brand-primary rounded-sm rotate-45 group-hover:rotate-90 transition-transform duration-500"></div>
					<span class="group-hover:translate-x-1 transition-transform">{brand.name}</span>
				</a>
				
				<div class="flex items-center gap-8">
					<div class="hidden md:flex items-center gap-6">
						{config.sections.map(section => (
							<a href={`#${section.id}`} class="text-[10px] uppercase tracking-[0.2em] font-medium text-brand-text/50 hover:text-brand-primary transition-colors">
								{section.type.replace('-', ' ')}
							</a>
						))}
					</div>
					
					<a href="#" class="bg-brand-primary text-white text-[11px] uppercase tracking-widest px-6 py-2.5 rounded-full font-bold hover:scale-105 transition-all shadow-lg shadow-brand-primary/20">
						Contact Core
					</a>
				</div>
			</nav>
		</header>

		<main>
			<slot />
		</main>

		<footer class="bg-brand-background border-t border-white/5 py-32 relative overflow-hidden">
			<!-- Visual Decoration -->
			<div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-6xl h-px bg-gradient-to-r from-transparent via-brand-primary to-transparent opacity-30"></div>
			
			<div class="container mx-auto px-6 relative z-10">
				<!-- Final CTA Block -->
				<div class="text-center mb-32 group">
					<p class="text-[10px] font-mono uppercase tracking-[0.5em] text-brand-primary mb-6">Engine Deployment Ready</p>
					<h2 class="text-5xl md:text-8xl font-black italic uppercase tracking-tighter mb-12 leading-none">
						¿Listo para el <br /> 
						<span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-primary to-brand-accent">Siguiente Nivel?</span>
					</h2>
					<a href="#" class="inline-block bg-white text-black text-xs uppercase tracking-[0.2em] px-16 py-6 rounded-full font-bold hover:bg-brand-primary hover:text-white hover:scale-105 transition-all duration-500 shadow-2xl">
						Iniciar Colaboración
					</a>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 gap-12 pt-20 border-t border-white/5">
					<div>
						<h3 class="text-2xl font-black italic tracking-tighter mb-4">{brand.name}</h3>
						<p class="text-brand-text/40 text-sm max-w-sm leading-relaxed">
							Arquitectando el futuro de las interfaces de alto rendimiento con precisión técnica y diseño centrado en datos.
						</p>
					</div>
					<div class="text-right">
						<p class="text-xs font-mono uppercase tracking-widest text-brand-primary mb-2">Engine Master</p>
						<p class="text-lg font-bold">Isaac Gonzalez</p>
						<p class="text-brand-text/30 text-xs">Full-Stack Architect & UI Engineer</p>
					</div>
				</div>
				
				<div class="mt-20 pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4 text-[10px] uppercase tracking-widest text-brand-text/20">
					<span>&copy; {new Date().getFullYear()} HYPER-SENSE-CORE Systems</span>
					<div class="flex gap-8">
						<span>v2.0.0 Deployment</span>
						<span>All Rights Reserved</span>
					</div>
				</div>
			</div>

			<!-- Background Glow -->
			<div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-96 h-96 bg-brand-primary/10 blur-[150px] rounded-full -z-10"></div>
		</footer>
	</body>
</html>
